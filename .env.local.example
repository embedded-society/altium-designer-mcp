# Altium Designer config for the on-site scripts (Verify-Libraries.ps1,
# Generate-Samples.ps1). Copy this file to .env.local (gitignored, per-machine)
# and set the path to YOUR Altium's X2.EXE. We do not auto-discover, because
# multiple Altium versions may be installed and the wrong one could be picked.
ALTIUM_EXE=C:\Program Files\Altium\AD24\X2.EXE
